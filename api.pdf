		&quot;fileUuid&quot; : String // 파일 상태 조회를 위한 임시 UUID
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-80c7-97f6-c18fe2bf9fc6" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/{fileUuid}/status - 파일 업로드 상태 조회 *</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-801f-820f-ce87dbb530d3" class="block-color-teal_background">파일 처리 상태를 조회하는 API</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80cd-8737-c1256142cf36" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80e7-bc25-c08ede3cd271" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-8044-aba2-e1364de4f78e" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileUuid: 업로드 상태 조회할 파일 UUID</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8059-8021-d2a98a7b2df8" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-804e-bb05-d0a21facaaeb" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8039-a5fc-dd92c34ffdd3" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-801d-a406-d955a5b8d969" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
    &quot;status&quot; : &quot;COMPLETE&quot;, // COMPLETE, PROCESSING, ERROR가 존재
    &quot;id&quot; : Long // 파일의 아이디
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="36c214c9-48c3-8044-823b-ee3e1709d44b" class="toggle"><li><details open=""><summary>[GET] /api/v2/files - 파일 검색 *</summary><div style="display:contents" dir="auto"><blockquote id="36c214c9-48c3-80e7-8ed8-d682e41793a4" class="block-color-teal_background">파일 정보를 조회하는 API<br/>쿼리 파라미터를 이용해서 검색 조건을 설정함.</blockquote></div><div style="display:contents" dir="auto"><p id="36c214c9-48c3-806b-a34d-e3c58183a285" class="">
</p></div><div style="display:contents" dir="auto"><p id="36c214c9-48c3-807b-8cf6-ce4644d1de37" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="36c214c9-48c3-809d-af16-fc69038ea4e7" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Query]
query: 검색어
category: 카테고리 //IMAGE, VIDEO 등 (null 주면 전체 조회)
sort: 정렬 방식 //name, size, originUpdatedAt, updatedAt
order: 정렬 방향 //asc, desc
size: 한 페이지에 보여줄 정보의 양 // 최대 1000
page: 조회할 페이지 // 0번부터 시작</code></pre></div><div style="display:contents" dir="auto"><p id="36c214c9-48c3-8064-b9b7-dadfc3644e0c" class="">
</p></div><div style="display:contents" dir="auto"><p id="36c214c9-48c3-80b4-adaa-dcc20d9e2f73" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="36c214c9-48c3-80d5-9af6-f061d2879ba7" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="36c214c9-48c3-8054-a085-c6875ec324e8" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
    &quot;hasNext&quot; : Boolean, //다음 페이지 존재 여부
    &quot;items&quot; : [ //검색 된 내용
        {
				  &quot;id&quot;: 0,
				  &quot;ownerId&quot;: 0, // 파일 올린 사람 ID
				  &quot;name&quot;: &quot;string&quot;, // 파일명(확장자 포함)
				  &quot;baseName&quot;: &quot;string&quot;, // 파일명
				  &quot;extension&quot;: &quot;string&quot;, // 확장자
				  &quot;relativePath&quot;: &quot;string&quot;, // 상대 경로
				  &quot;parentPath&quot;: &quot;string&quot;, // 파일이 들어있는 폴더 경로
				  &quot;mimeType&quot;: &quot;string&quot;, // MIME 타입
				  &quot;size&quot;: 0, // 파일 크기(바이트)
				  &quot;videoCodec&quot;: &quot;string&quot;, // 비디오 코덱
				  &quot;audioCodec&quot;: &quot;string&quot;, // 오디오 코덱
				  &quot;width&quot;: 0, // 이미지 너비
				  &quot;height&quot;: 0, // 이미지 높이
				  &quot;duration&quot;: 0, // 재생 시간
				  &quot;bitrate&quot;: 0, // 비트레이트
				  &quot;orientation&quot;: 0, // 이미지 회전 정보
				  &quot;lat&quot;: 0.1, // 위도
				  &quot;lon&quot;: 0.1, // 경도
				  &quot;fps&quot;: 0.1, // 프레임
				  &quot;format&quot;: &quot;string&quot;, // 영상 포멧 정보
				  &quot;capturedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 사진 찍힌 날짜
				  &quot;originUpdatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 파일 마지막 수정시각
				  &quot;createdAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최초 등록 시점
				  &quot;updatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최종 수정 시점
				  &quot;category&quot;: &quot;string&quot;, // 파일의 카테고리
				  &quot;isShared&quot;: true, // 공유 된 파일인지 여부
				  &quot;shareKeys&quot;: [ // 공유 키 리스트
				    &quot;string&quot;
				  ]
				}
    ]
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-800b-9298-de75238612a6" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/{fileId} - 파일 정보 조회 *</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-804a-b155-c55b17edd389" class="block-color-teal_background">파일 정보 조회하는 API</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80eb-adbb-d03fbd67a25c" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-805b-9540-ddd9c6fb308f" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80d9-a643-d043f057ede6" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 조회할 파일 ID</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80ae-a139-d700edbc24a2" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80b2-9484-ff4e79743ef5" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8083-8fcd-da4cff619526" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="2f3214c9-48c3-80fc-a1b8-ed99f85527c0" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
  &quot;id&quot;: 0,
  &quot;uuid&quot;: String, // 파일 UUID
  &quot;ownerId&quot;: 0, // 파일 올린 사람 ID
  &quot;name&quot;: &quot;string&quot;, // 파일명(확장자 포함)
  &quot;baseName&quot;: &quot;string&quot;, // 파일명
  &quot;extension&quot;: &quot;string&quot;, // 확장자
  &quot;relativePath&quot;: &quot;string&quot;, // 상대 경로
  &quot;parentPath&quot;: &quot;string&quot;, // 파일이 들어있는 폴더 경로
  &quot;mimeType&quot;: &quot;string&quot;, // MIME 타입
  &quot;size&quot;: 0, // 파일 크기(바이트)
  &quot;videoCodec&quot;: &quot;string&quot;, // 비디오 코덱
  &quot;audioCodec&quot;: &quot;string&quot;, // 오디오 코덱
  &quot;width&quot;: 0, // 이미지 너비
  &quot;height&quot;: 0, // 이미지 높이
  &quot;duration&quot;: 0, // 재생 시간
  &quot;bitrate&quot;: 0, // 비트레이트
  &quot;orientation&quot;: 0, // 이미지 회전 정보
  &quot;lat&quot;: 0.1, // 위도
  &quot;lon&quot;: 0.1, // 경도
  &quot;fps&quot;: 0.1, // 프레임
  &quot;format&quot;: &quot;string&quot;, // 영상 포멧 정보
  &quot;capturedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 사진 찍힌 날짜
  &quot;originUpdatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 파일 마지막 수정시각
  &quot;createdAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최초 등록 시점
  &quot;updatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최종 수정 시점
  &quot;category&quot;: &quot;string&quot;, // 파일의 카테고리
  &quot;isShared&quot;: true, // 공유 된 파일인지 여부
  &quot;shareKeys&quot;: [ // 공유 키 리스트
    &quot;string&quot;
  ]
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-8038-922c-cb608fa59087" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/{fileUuid}/thumbnail - 파일 썸네일 조회 *</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-801f-9037-ea2ccbf10ace" class="block-color-teal_background">파일 썸네일 조회하는 API</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80ae-9cba-f4d49a94f168" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8049-845c-fd188a167714" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-8061-b446-d1b5a52a45f5" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileUuid: 조회할 파일 UUID</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8031-97fd-ccf33ab565cd" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-806d-bed6-d1caef22e1ed" class=""><strong>Response Header</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80b6-ae89-f47db5a2f948" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">Content-Type: image/jpeg</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-802e-ac9e-ed650f163ea9" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8012-9994-dec4bf2db7bc" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80dd-928b-d44de9b6f2fd" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-8079-9332-ce219a4c7b82" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">이미지 데이터</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-807a-beb0-eb93872b2321" class="toggle"><li><details open=""><summary>[PATCH] /api/v2/files/{fileId} - 파일 정보 수정 *</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-80a8-a5d1-c4125488e3cc" class="block-color-teal_background">파일 정보 수정하는 API<br/>여기서 파일 위치를 옮길 수 있음</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80aa-8586-ed3f6f978bee" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8061-be86-eba1b16d63d7" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-8063-9ffd-f916179d5dfb" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 수정할 파일 ID</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8051-8646-ead3ea17a47b" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80e3-a651-c7a2cbd17135" class=""><strong>Request Body</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80f6-af7b-c68d85f5b452" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
    &quot;folderId&quot; : Long, //위치 옮길 대상 폴더 ID
    &quot;originUpdatedAt&quot; : &quot;2026-01-22T10:43:39.008Z&quot; //파일 수정일
}</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-804a-bd7c-e3ba0187ee23" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8094-988a-eb0fb0a9fc4a" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-807d-a0e0-f2cc369d994f" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="2f3214c9-48c3-806f-9bff-d3c900399617" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
  &quot;id&quot;: 0,
  &quot;uuid&quot;: String, // 파일 UUID
  &quot;ownerId&quot;: 0, // 파일 올린 사람 ID
  &quot;name&quot;: &quot;string&quot;, // 파일명(확장자 포함)
  &quot;baseName&quot;: &quot;string&quot;, // 파일명
  &quot;extension&quot;: &quot;string&quot;, // 확장자
  &quot;relativePath&quot;: &quot;string&quot;, // 상대 경로
  &quot;parentPath&quot;: &quot;string&quot;, // 파일이 들어있는 폴더 경로
  &quot;mimeType&quot;: &quot;string&quot;, // MIME 타입
  &quot;size&quot;: 0, // 파일 크기(바이트)
  &quot;videoCodec&quot;: &quot;string&quot;, // 비디오 코덱
  &quot;audioCodec&quot;: &quot;string&quot;, // 오디오 코덱
  &quot;width&quot;: 0, // 이미지 너비
  &quot;height&quot;: 0, // 이미지 높이
  &quot;duration&quot;: 0, // 재생 시간
  &quot;bitrate&quot;: 0, // 비트레이트
  &quot;orientation&quot;: 0, // 이미지 회전 정보
  &quot;lat&quot;: 0.1, // 위도
  &quot;lon&quot;: 0.1, // 경도
  &quot;fps&quot;: 0.1, // 프레임
  &quot;format&quot;: &quot;string&quot;, // 영상 포멧 정보
  &quot;capturedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 사진 찍힌 날짜
  &quot;originUpdatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 파일 마지막 수정시각
  &quot;createdAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최초 등록 시점
  &quot;updatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최종 수정 시점
  &quot;category&quot;: &quot;string&quot;, // 파일의 카테고리
  &quot;isShared&quot;: true, // 공유 된 파일인지 여부
  &quot;shareKeys&quot;: [ // 공유 키 리스트
    &quot;string&quot;
  ]
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-80c2-82a0-e12adcda8edd" class="toggle"><li><details open=""><summary>[DELETE] /api/v2/files/{fileId} - 파일 휴지통으로 이동 !</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-80a6-8e0a-d2e1121dafd0" class="block-color-teal_background">파일 삭제하는 API</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-807d-bcf1-fb81635ec87b" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80ce-86e7-f25d8f058959" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80b7-95a8-fa98875157e7" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 삭제할 파일 ID</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8003-b19c-f8fb5d9e8a9e" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80a0-9ab2-f931a36d16b9" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80e9-968a-e73c7b2ed72a" class=""><code>Status: 204</code></p></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-80de-909c-c349a97c57de" class="toggle"><li><details open=""><summary>[POST] /api/v2/files/{fileId}/shares - 파일 공유 링크 생성 *</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-8068-b81d-cb314747c29c" class="block-color-teal_background">파일 공유 링크 생성하는 API</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80eb-af03-d98003286ab0" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8001-b8c8-c2c98bd106c1" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80dd-9ea1-ead731c3935d" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 공유링크 생성할 파일 ID</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-804c-844b-d35aad176ddb" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8009-810e-d6408c436a09" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8068-b166-d64e0d777c42" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80c3-be40-dfbd873bc9ba" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
    &quot;id&quot; : Long,
    &quot;fileId&quot; : Long,
    &quot;shareKey&quot; : String // 실제로는 &#x27;/api/v2/auth/files/{shareKey}/**&#x27;로 접근
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-8030-a7f8-c4eeaa2ce578" class="">
</p></div><div style="display:contents" dir="auto"><h3 id="38f214c9-48c3-80d8-a448-c544d27efc8d" class="">갤러리</h3></div><div style="display:contents" dir="auto"><ul id="38f214c9-48c3-800e-83ab-d64ad16ef321" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/gallery - 갤러리 조회 *</summary><div style="display:contents" dir="auto"><blockquote id="38f214c9-48c3-801b-903e-f20bd3fd6405" class="block-color-teal_background">갤러리 목록을 조회하는 API</blockquote></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-80a2-a739-da1129c5639c" class="">
</p></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-80bf-b8fd-fa1010f2c2c6" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="38f214c9-48c3-804f-99ba-ce468c47b9f8" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Query]
order: 정렬 방향 //asc, desc
size: 한 페이지에 보여줄 정보의 양 // 최대 1000
page: 조회할 페이지 // 0번부터 시작</code></pre></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-8005-945f-fe949f64206a" class="">
</p></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-8090-8bfa-d61a7c0ac5cf" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-803e-8fe4-f5a6a86dd6e5" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="38f214c9-48c3-8027-b3c7-e0465c1f69ed" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">{
    &quot;hasNext&quot; : Boolean, //다음 페이지 존재 여부
    &quot;items&quot; : [ //검색 된 내용
        {
				  &quot;id&quot;: 0,
				  &quot;ownerId&quot;: 0, // 파일 올린 사람 ID
				  &quot;name&quot;: &quot;string&quot;, // 파일명(확장자 포함)
				  &quot;baseName&quot;: &quot;string&quot;, // 파일명
				  &quot;extension&quot;: &quot;string&quot;, // 확장자
				  &quot;relativePath&quot;: &quot;string&quot;, // 상대 경로
				  &quot;parentPath&quot;: &quot;string&quot;, // 파일이 들어있는 폴더 경로
				  &quot;mimeType&quot;: &quot;string&quot;, // MIME 타입
				  &quot;size&quot;: 0, // 파일 크기(바이트)
				  &quot;videoCodec&quot;: &quot;string&quot;, // 비디오 코덱
				  &quot;audioCodec&quot;: &quot;string&quot;, // 오디오 코덱
				  &quot;width&quot;: 0, // 이미지 너비
				  &quot;height&quot;: 0, // 이미지 높이
				  &quot;duration&quot;: 0, // 재생 시간
				  &quot;bitrate&quot;: 0, // 비트레이트
				  &quot;orientation&quot;: 0, // 이미지 회전 정보
				  &quot;lat&quot;: 0.1, // 위도
				  &quot;lon&quot;: 0.1, // 경도
				  &quot;fps&quot;: 0.1, // 프레임
				  &quot;format&quot;: &quot;string&quot;, // 영상 포멧 정보
				  &quot;capturedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 사진 찍힌 날짜
				  &quot;originUpdatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 파일 마지막 수정시각
				  &quot;createdAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최초 등록 시점
				  &quot;updatedAt&quot;: &quot;2026-05-26T07:30:16.640Z&quot;, // 서버에 최종 수정 시점
				  &quot;category&quot;: &quot;string&quot;, // 파일의 카테고리
				  &quot;isShared&quot;: true, // 공유 된 파일인지 여부
				  &quot;shareKeys&quot;: [ // 공유 키 리스트
				    &quot;string&quot;
				  ]
				}
    ]
}</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><p id="38f214c9-48c3-80de-8073-e245c467e9b5" class="">
</p></div><div style="display:contents" dir="auto"><h3 id="2f1214c9-48c3-8082-b485-e87ddca467e8" class="">스트리밍 및 다운로드</h3></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-8027-93e1-d857b9ce01aa" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/{fileId}/content - 파일 다운로드 &amp; 직접 스트리밍 * </summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-8070-b168-ff17580b9f29" class="block-color-teal_background">파일을 다운로드 하거나 직접 스트리밍 하는 API<br/>브라우저가 해당 코덱을 지원할 때 이 API로 직접 스트리밍 함.</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8098-9efa-de5d9cc84400" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80ee-aaed-d5c5d24023ad" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80f8-bdbc-f1c8dd813041" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 조회할 파일 ID

[Query]
download: 이 요청이 다운로드인지 여부 (비어있거나 False이면 직접 스트리밍)</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-805d-9e07-cd35d9d62957" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8004-9afa-dfb9b0bb31a6" class=""><strong>Response Header</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-8072-9b66-d1e97f776415" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">Content-Type: 파일에 맞는 타입
Content-Disposition: attachment; filename=&quot;확장자를 포함한 파일명&quot;
Content-Length: 파일 크기</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-800a-8b62-c5ebcfeae9b3" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-808d-876d-ed281ed74285" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8031-b8b6-da4a258d7753" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-803a-8370-c2151521faaa" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">바이너리 데이터</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="2f0214c9-48c3-80b3-999f-d29f79482a8e" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/{fileId}/stream - 파일 실시간 h264 변환 스트리밍 *</summary><div style="display:contents" dir="auto"><blockquote id="2f0214c9-48c3-8013-9299-d16df238342c" class="block-color-teal_background">파일을 스트리밍하는 API<br/>브라우저가 해당 코덱을 지원하지 않을 때 h264로 변환해서 스트리밍</blockquote></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8082-ae7c-fbb73991f723" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-80ac-a95a-c2549f784a8f" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-80b5-8a50-c5248bebf58f" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 조회할 파일 ID

[Query]
start: double // 스트리밍 시작 초</code></pre></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-806c-a6a5-f5997e701b15" class="">
</p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8081-b6d7-d5474dececce" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="2f0214c9-48c3-8068-a79c-f1db36c2bd63" class=""><code>Status: 206</code></p></div><div style="display:contents" dir="auto"><pre id="2f0214c9-48c3-8034-a554-cbbbedfb1fbf" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">바이너리</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><ul id="379214c9-48c3-80f4-84bb-c5f6f2d4c5af" class="toggle"><li><details open=""><summary>[GET] /api/v2/files/{fileId}/stream/{hlsFile} - 파일 실시간 HLS 변환 스트리밍 *</summary><div style="display:contents" dir="auto"><blockquote id="379214c9-48c3-80f6-ac29-d97c7e6dd1a7" class="block-color-teal_background">파일을 스트리밍하는 API<br/>브라우저가 해당 코덱을 지원하지 않을 때 HLS로 변환해서 스트리밍</blockquote></div><div style="display:contents" dir="auto"><p id="379214c9-48c3-8026-b959-de3bbd9470a7" class="">
</p></div><div style="display:contents" dir="auto"><p id="379214c9-48c3-80ce-ade0-ed38a5b96ea7" class=""><strong>Parameter</strong></p></div><div style="display:contents" dir="auto"><pre id="379214c9-48c3-80ff-8e0a-cb411b324321" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">[Path]
fileId: 조회할 파일 ID
hlsFile: 조회할 HLS 파일</code></pre></div><div style="display:contents" dir="auto"><p id="379214c9-48c3-80a7-8c8c-c8deb3bee06e" class="">
</p></div><div style="display:contents" dir="auto"><p id="379214c9-48c3-8083-ae50-d055dc815de1" class=""><strong>Response Body</strong></p></div><div style="display:contents" dir="auto"><p id="379214c9-48c3-80ef-bcda-c698fb8cb39c" class=""><code>Status: 200</code></p></div><div style="display:contents" dir="auto"><pre id="379214c9-48c3-80d8-880f-c2bd5bee3933" class="code code-wrap"><code class="language-json" style="white-space:pre-wrap;word-break:break-all">바이너리</code></pre></div></details></li></ul></div><div style="display:contents" dir="auto"><p id="2f1214c9-48c3-8047-8838-d14b8c04512d" class="">
